<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="RedBus Single Test Suite" parallel="false">
    <parameter name="appURL" value="https://www.redbus.in/" />
    <parameter name="browser" value="chrome" />
    <parameter name="username" value="existing.user@example.com" />
    <parameter name="password" value="ExistingPassword123!" />
    <parameter name="sourceCity" value="Hyderabad" />
    <parameter name="destinationCity" value="Vijayawada" />
    <parameter name="travelDate" value="01-01-2027" />
    <parameter name="fullName" value="Single Test User" />
    <parameter name="email" value="single.user@example.com" />
    <parameter name="mobileNumber" value="9123456789" />

    <test name="Create Account Test">
        <classes>
            <class name="tests.CreateAccountTests">
                <methods>
                    <include name="verifyUserCanCreateAccount" />
                </methods>
            </class>
        </classes>
    </test>
</suite>
