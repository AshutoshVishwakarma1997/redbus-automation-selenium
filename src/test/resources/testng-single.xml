<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="SauceDemo Single Test Suite" parallel="false">
    <parameter name="appURL" value="https://www.saucedemo.com/" />
    <parameter name="browser" value="chrome" />
    <parameter name="username" value="standard_user" />
    <parameter name="password" value="secret_sauce" />
    <parameter name="invalidUsername" value="invalid_user" />
    <parameter name="invalidPassword" value="invalid_password" />
    <parameter name="productName" value="Sauce Labs Backpack" />
    <parameter name="firstName" value="Single" />
    <parameter name="lastName" value="Tester" />
    <parameter name="postalCode" value="560001" />

    <test name="Login Test">
        <classes>
            <class name="tests.LoginTests">
                <methods>
                    <include name="verifyUserCanLogin" />
                </methods>
            </class>
        </classes>
    </test>
</suite>
