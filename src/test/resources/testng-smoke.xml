<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="RedBus Smoke Suite" parallel="tests">
    <parameter name="appURL" value="https://www.redbus.in/" />
    <parameter name="browser" value="chrome" />
    <parameter name="username" value="existing.user@example.com" />
    <parameter name="password" value="ExistingPassword123!" />
    <parameter name="sourceCity" value="Bangalore" />
    <parameter name="destinationCity" value="Chennai" />
    <parameter name="travelDate" value="25-12-2026" />
    <parameter name="fullName" value="Smoke Suite User" />
    <parameter name="email" value="smoke.user@example.com" />
    <parameter name="mobileNumber" value="9876543210" />

    <test name="Smoke Tests">
        <parameter name="username" value="smoke.override@example.com" />
        <groups>
            <run>
                <include name="smoke" />
                <exclude name="disabled" />
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTests" />
        </classes>
    </test>
</suite>

